# Container Host Configuration
HOST_IP=<YOUR_HOST_IP>

# GitHub Repository Info (Lowercase)
GITHUB_REPOSITORY_OWNER_LC=svveec0d3
REPOSITORY_NAME=secure-deploy

# n8n image version to deploy — set this to a specific released version (e.g. 1.55.3)
# Check available versions: https://github.com/svveec0d3/secure-deploy/releases
# To rollback: change both fields below to a previous version and run: docker compose up -d
N8N_IMAGE_VERSION=latest

# Exact identifier of the GHCR image to run (populated automatically by install.sh)
# Format: @sha256:<hex> (preferred) OR :<version> (fallback)
# To rollback: set this to the exact digest or version tag
N8N_IMAGE_IDENTIFIER=

# ── Container Resource Limits ─────────────────────────────────────────────
# Set by install.sh — adjust and run `docker compose up -d` to apply changes
MEM_LIMIT=1g
CPU_LIMIT=1.0
PIDS_LIMIT=200
